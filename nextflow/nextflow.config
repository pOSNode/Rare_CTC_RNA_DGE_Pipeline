// ============================================================
// nextflow.config
// CTC low-input RNA-seq pipeline configuration.
// All biological parameters are pre-tuned for rare-cell CTC
// transcriptomics. Adjust only if you have specific evidence.
// ============================================================

manifest {
    name        = 'ctc-rnaseq-pipeline'
    author      = 'Owais Siddiqi'
    description = 'Low-input RNA-seq DGE pipeline for CTC transcriptomics'
    version     = '1.0.0'
    nextflowVersion = '>=23.04.0'
}

// ------------------------------------------------------------
// Default parameters
// Tuned for CTC low-input RNA: sparse counts, small cell
// numbers, and low library complexity require relaxed
// filtering and specialised normalisation.
// ------------------------------------------------------------
params {
    // -- Required (no defaults — must be supplied by user)
    samplesheet   = null
    salmon_index  = null
    gtf           = null
    outdir        = "results"

    // -- Pipeline metadata
    pipeline_version = "1.0.0"
    help             = false

    // -- Low-input mode (set true for CTC samples)
    low_input_mode = true

    // -- Filtering: relaxed for low-input sparse count matrices
    min_cpm           = 0.1     // Standard pipelines use 0.5 — reduced for rare transcripts
    min_sam           = 2
    exclusive_min_cpm = 0.05    // Retain condition-exclusive markers at very low CPM
    exclusive_min_sam = 1

    // -- Statistical testing
    fdr_cutoff  = 0.1           // More lenient than standard 0.05 given low power
    lfc_treat   = 0.5           // glmTreat LFC threshold
    use_treat   = false
    prior_count = 0.5           // Lower prior count preserves low-count signal

    // -- Gene-level options
    priority_genes = ""         // e.g. "ERBB2,ESR1,PGR,MKI67,VIM,CDH1"

    // -- Execution
    threads = 4
    species = "human"
}

// ------------------------------------------------------------
// Docker configuration (single image for all processes)
// ------------------------------------------------------------
docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    container = 'owaissiddiqi/ctc-rnaseq:1.0.0'

    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
    }
    withLabel: 'process_medium' {
        cpus   = { params.threads }
        memory = '8.GB'
    }
    withLabel: 'process_high' {
        cpus   = { params.threads }
        memory = '16.GB'
    }

    errorStrategy = 'retry'
    maxRetries    = 2
}

// ------------------------------------------------------------
// Execution profiles
// ------------------------------------------------------------
profiles {

    standard {
        // Default: local Docker execution
        docker.enabled = true
    }

    test {
        // Minimal resources for CI / demo run
        params.samplesheet  = "test_data/sample_sheet.csv"
        params.salmon_index = "test_data/refs/salmon_index"
        params.gtf          = "test_data/refs/gencode.v46.annotation.subset.gtf"
        params.outdir       = "test_results"
        params.low_input_mode = true

        process {
            cpus   = 2
            memory = '4.GB'
        }
    }

    hpc {
        // Extend for SLURM/HPC if needed in future
        executor {
            name           = 'slurm'
            queueSize      = 50
            pollInterval   = '30 sec'
        }
        singularity {
            enabled    = true
            autoMounts = true
        }
        docker.enabled = false
    }
}

// ------------------------------------------------------------
// Reporting and tracing (built-in Nextflow audit)
// ------------------------------------------------------------
report {
    enabled   = true
    file      = "${params.outdir}/audit/nextflow_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/audit/nextflow_timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/audit/nextflow_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,cpus,memory,rss,peak_rss,container'
}

dag {
    enabled   = true
    file      = "${params.outdir}/audit/pipeline_dag.html"
    overwrite = true
}
